<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="#FAEEDA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:text="ĐĂNG KÝ TÀI KHOẢN"
        android:textColor="#623E1E"
        android:textSize="24sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtTenDangNhap"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input"
        android:hint="Tên đăng nhập"
        android:inputType="text"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:textColor="#623E1E" />

    <EditText
        android:background="@drawable/bg_input"
        android:id="@+id/edtEmailDK"
        android:inputType="textEmailAddress"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Nhập email"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:textColor="#623E1E" />

    <!-- Password field with visibility toggle -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="10dp">

        <EditText
            android:id="@+id/edtPassDK"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_input"
            android:hint="Nhập mật khẩu"
            android:inputType="textPassword"
            android:padding="10dp"
            android:paddingEnd="50dp"
            android:textColor="#623E1E" />

        <ImageButton
            android:id="@+id/btnTogglePasswordDK"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical|end"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Toggle password visibility"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_eye_hide" />
    </FrameLayout>

    <!-- Confirm password field with visibility toggle -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/edtRePassDK"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_input"
            android:hint="Xác nhận mật khẩu"
            android:inputType="textPassword"
            android:padding="10dp"
            android:paddingEnd="50dp"
            android:textColor="#623E1E" />

            <ImageButton
                android:id="@+id/btnToggleConfirmPasswordDK"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical|end"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="Toggle password visibility"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_eye_hide" />
    </FrameLayout>

    <Button
        android:backgroundTint="#E0C8A5"
        android:id="@+id/btnXacNhanDK"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đăng Ký Ngay"
        android:textColor="#623E1E"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvDaCoTK"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="Đã có tài khoản"
        android:textColor="#4E342E"
        android:textStyle="bold" />

</LinearLayout>