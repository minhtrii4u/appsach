<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_search_input"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:id="@+id/edtSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/btnRemoveSection"
            android:background="@android:color/transparent"
            android:hint="Tiêu đề phần (ví dụ: Chương 1)"
            android:padding="8dp"
            android:textColor="#3E2723"
            android:textStyle="bold"
            android:textSize="16sp" />
        <ImageButton
            android:id="@+id/btnRemoveSection"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#D32F2F" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginVertical="4dp"/>

    <EditText
        android:id="@+id/edtSectionContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:hint="Nhập nội dung chi tiết của phần này tại đây..."
        android:minLines="5"
        android:gravity="top"
        android:padding="8dp"
        android:textColor="#4E342E"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginVertical="4dp"/>

    <!-- Audio selection for this specific section -->
    <LinearLayout
        android:id="@+id/layoutUploadAudioSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="4dp">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            app:tint="#8D6E63" />
        <TextView
            android:id="@+id/tvAudioFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Chưa chọn tệp âm thanh"
            android:textColor="#8D6E63"
            android:textSize="12sp"
            android:ellipsize="end"
            android:singleLine="true"/>
        <Button
            android:id="@+id/btnSelectAudio"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_search_border"
            android:text="Chọn tệp"
            android:textAllCaps="false"
            android:textColor="#8D6E63"
            android:textSize="12sp"
            android:paddingHorizontal="12dp" />
    </LinearLayout>
</LinearLayout>
