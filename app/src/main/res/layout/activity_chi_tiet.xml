<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quay lại"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            tools:ignore="TextContrastCheck"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="180dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="10dp">
                <ImageView
                    android:id="@+id/imgChiTiet"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/sach1"
                    android:scaleType="centerCrop"
                    tools:ignore="ContentDescription" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginLeft="20dp">

                <TextView
                    android:id="@+id/tvTenChiTiet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên Sách"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:maxLines="3"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvTacGiaChiTiet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tác giả"
                    android:textColor="#BBBBBB"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    tools:ignore="TextContrastCheck"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hội viên"
                    android:textColor="#00C853"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#1A3322"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginTop="10dp"
                    tools:ignore="TextContrastCheck"/>

                <TextView
                    android:id="@+id/btnDocSach"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Đọc sách"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="#00C853"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="5dp"
                    tools:ignore="TextContrastCheck"/>

            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="15dp">

            <TextView
                android:id="@+id/btnNgheAudio"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Nghe Audio"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#333333"
                android:gravity="center"
                android:layout_marginRight="10dp"
                tools:ignore="TextContrastCheck"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Lưu"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#333333"
                android:gravity="center"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                tools:ignore="TextContrastCheck"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Giới thiệu tác phẩm"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"/>

        <TextView
            android:id="@+id/tvTomTat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nội dung tóm tắt sẽ hiện ở đây..."
            android:textColor="#DDDDDD"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp"
            android:layout_marginTop="10dp"
            tools:ignore="TextContrastCheck"/>

    </LinearLayout>
</ScrollView>