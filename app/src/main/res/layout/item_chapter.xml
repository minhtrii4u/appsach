<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutChapterItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="12dp">

        <!-- Header: Always visible -->
        <RelativeLayout
            android:id="@+id/layoutChapterHeader"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:paddingHorizontal="20dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvChapterIndex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="01"
                android:textColor="#555555"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChapterTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"
                android:layout_toEndOf="@id/tvChapterIndex"
                android:layout_toStartOf="@+id/imgChapterArrow"
                android:text="Phần 1: Khởi đầu cuộc hành trình"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <ImageView
                android:id="@+id/imgChapterArrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_chevron_right"
                app:tint="#888888" />

        </RelativeLayout>

        <!-- Expandable Actions: Initially hidden -->
        <LinearLayout
            android:id="@+id/layoutChapterActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDocPhan"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#00C853"
                android:text="Đọc phần 1"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNgheAudioPhan"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="#262626"
                android:text="Nghe Audio"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:strokeColor="#444444"
                app:strokeWidth="1dp"
                app:icon="@android:drawable/ic_lock_silent_mode_off"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/white" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
