<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Khi focus -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#E0C8A5"/>
            <stroke
                android:width="2dp"
                android:color="#B08968"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Bình thường -->
    <item>
        <shape>
            <solid android:color="#E0C8A5"/>
            <stroke
                android:width="1dp"
                android:color="#CBB89D"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

</selector>